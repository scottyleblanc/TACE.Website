{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3PutDelete",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::tacedata-s3-bucket-02/tacedata-site/*"
    },
    {
      "Sid": "S3List",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::tacedata-s3-bucket-02",
      "Condition": {
        "StringLike": {
          "s3:prefix": "tacedata-site/*"
        }
      }
    },
    {
      "Sid": "CloudFrontInvalidation",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::540420948767:distribution/E1144JDZXTVLFW"
    }
  ]
}
