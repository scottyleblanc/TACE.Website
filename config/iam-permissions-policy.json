{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3PutDelete",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::REDACTED_S3_BUCKET/tacedata-site/*"
    },
    {
      "Sid": "S3List",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::REDACTED_S3_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": "tacedata-site/*"
        }
      }
    },
    {
      "Sid": "CloudFrontInvalidation",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": "arn:aws:cloudfront::REDACTED_AWS_ACCOUNT_ID:distribution/REDACTED_CF_DIST_ID"
    }
  ]
}
